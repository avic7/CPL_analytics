# CPL Player Archtypes 
```{r}

#Define values in each slice before doing archtypes 

# Attacking slices
finishing_slices <- c(
  "goals_per_90_rank",
  "shots_on_target_pct_rank",
  "shots_per_90_rank",
  "shots_on_target_per_90_rank",
  "box_touches_per_90_rank",
  "big_chance_conversion_pct_rank"
)

# Creation slices
creation_slices <- c(
  "assists_per_90_rank",
  "key_passes_per_90_rank",
  "big_chances_created_per_90_rank",
  "progressive_carries_per_90_rank",
  "dribble_success_rate_rank"
)

# Physical slices
physical_slices <- c(
  "aerial_duels_won_percentage_rank",
  "duels_won_percentage_rank",
  "recoveries_per_90_rank",
  "tackles_won_per_90_rank",
  "fouls_won_per_90_rank"
)


# Create player(forward) archtypes 


cpl_player_archetypes <- pizza_percentiles %>%
  rowwise() %>%
  mutate(
    finishing_score   = round(mean(c_across(all_of(finishing_slices))), 0),
    creation_score    = round(mean(c_across(all_of(creation_slices))), 0),
    physical_score    = round(mean(c_across(all_of(physical_slices))), 0),
    max_score         = max(c(finishing_score, creation_score, physical_score))
  ) %>%
  ungroup() %>%

  mutate(
    archetype = case_when(
      
      # The rare all-rounder — elite across all three dimensions
      finishing_score >= 70 & creation_score >= 60 & physical_score >= 60 ~ "Complete Forward",
      
      # Pure goalscorer — lethal but doesn't contribute much else
      finishing_score >= 70 & creation_score < 40 ~ "Poacher",
      
      # High press, high recoveries, high tackles — energetic forward
      physical_score >= 70 & recoveries_per_90_rank >= 70 & tackles_won_per_90_rank >= 70 ~ "Pressing Forward",
      
      # Wins headers, dominates duels, aerial threat
      physical_score >= 70 & aerial_duels_won_percentage_rank >= 70 ~ "Target Forward",
      
      # Creates more than he scores
      creation_score > finishing_score & creation_score >= 60 ~ "Creator Forward",
      
      # Decent creator and physically involved but not a scorer
      creation_score >= 50 & finishing_score < 60 & physical_score >= 55 ~ "Support Forward",
      
      # Nobody home across all three
      max_score < 45 | (finishing_score < 35 & creation_score < 35) ~ "Low Impact Forward",
      
      # Decent across the board but not elite anywhere
      TRUE ~ "Balanced Forward"
    )
  ) %>%

  select(
    first_name, last_name, team, minutes_played,
    finishing_score, creation_score, physical_score, archetype, nationality
  ) %>%
  arrange(desc(finishing_score))


print(cpl_player_archetypes)

```

# Building a piiza chart 

```{r warning=FALSE, message=FALSE}

build_pizza <- function(player_data, slice_columns, chart_title) {
  plot_data <- player_data %>%
    select(all_of(slice_columns)) %>%
    pivot_longer(cols = everything(), names_to = "metric", values_to = "percentile") %>%
    mutate(
      metric = metric %>%
        str_replace_all("shots_on_target_pct_rank", "Shot Accuracy") %>%
        str_replace_all("_per_90_rank", "") %>%
        str_replace_all("_pct_rank", "") %>%
        str_replace_all("_percentage_rank", "") %>%
        str_replace_all("_rank", "") %>%
        str_replace_all("_", "\n") %>%
        str_to_title()
    )
  
  ggplot(plot_data, aes(x = metric, y = percentile, fill = percentile)) +
    geom_hline(yintercept = c(25, 50, 75, 100), color = "gray75", linetype = "dashed", linewidth = 0.4) +
    geom_bar(stat = "identity", color = "white", linewidth = 0.5, width = 1, alpha = 0.85) +
    
    geom_text(aes(label = percentile), vjust = 1.5, size = 3.5, fontface = "bold", color = "gray15", family = "montserrat") +
    
    coord_polar() +
    scale_y_continuous(limits = c(0, 100), breaks = c(25, 50, 75, 100)) +
    scale_fill_gradient2(
      low = "#1B365D",      
      mid = "#f5f5f5",      
      high = "#C8102E",    
      midpoint = 50
    ) +
    
    # 1. Lock in the minimal theme
    theme_minimal(base_family = "montserrat") + 
    labs(title = chart_title) +
    theme(
      # 2. Pull the title down slightly to close the gap
      plot.title = element_text(face = "bold", size = 13, hjust = 0.5, family = "montserrat", margin = margin(b = -15)),
      
      axis.title = element_blank(),
      axis.text.y = element_blank(),
      axis.text.x = element_text(size = 8, face = "bold", family = "montserrat"),
      legend.position = "none",
      panel.grid.major.y = element_blank(), 
      panel.grid.major.x = element_line(color = "gray85", linetype = "dashed"),
      
      # 3. Bulletproof transparency so the grey boxes NEVER come back
      panel.background = element_rect(fill = "transparent", color = NA),
      plot.background = element_rect(fill = "transparent", color = NA)
    )
}

