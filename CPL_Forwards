# Filter out forwards only 
```{r}
focused_player_stats <- players_raw %>%
  select(
    first_name = mediaFirstName,
    last_name = mediaLastName,
    team = team_name,
    position = roleLabel,
    stats,
    nationality
  ) %>%
  # NUKE EVERYONE WHO ISN'T A FORWARD RIGHT HERE
  filter(position == "Forward") %>%
  
  # Now do the heavy lifting only on the forwards
  unnest(stats) %>%
  select(first_name, last_name, team, position, statsLabel, statsValue, nationality) %>%
  
 filter(statsLabel %in% c(
  # Identifiers / Base
  "Minutes played",
  "Games played",   
  
  # Attacking
  "Total Shots",
  "Shots On Target ( inc goals )",
  "Goals",
  "Goals Openplay",
  "Total Big Chances Scored",
  "Total Big Chances Missed",
  "Total Touches In Opposition Box",
  
  # Creation 
  "Goal Assists",
  "Key Passes (Attempt Assists)",
  "Total Big Chances Created",
  "Progressive Carries",
  "Successful Dribbles",
  "Unsuccessful Dribbles",
  
  # Physical
  "Aerial Duels Won Percentage",
  "Duels Won Percentage",
  "Recoveries",
  "Tackles Won",
  "Total Fouls Won"
)) %>% 
  
  # Force values to be numeric
  mutate(statsValue = as.numeric(statsValue)) %>%
  # Nuke duplicate stat records for the same player, team, and metric
  distinct(first_name, last_name, team, position, statsLabel, .keep_all = TRUE) %>%
  
  pivot_wider(
    names_from = statsLabel,
    values_from = statsValue
  ) %>%
  clean_names()  

```


# Furhter drill down and make new features 
```{r}

pizza_per90 <- focused_player_stats %>%
  
  # Apply minutes filter 
  filter(minutes_played >= 750) %>%
  
  mutate(
    # ATTACKING (per-90s)
    goals_per_90                = (goals / minutes_played) * 90,
    shots_per_90                = (total_shots / minutes_played) * 90,
    shots_on_target_per_90      = (shots_on_target_inc_goals / minutes_played) * 90,
    box_touches_per_90          = (total_touches_in_opposition_box / minutes_played) * 90,
    
    # percentage 
    big_chance_conversion_pct   = ifelse(
      (total_big_chances_scored + total_big_chances_missed) > 0,
      total_big_chances_scored / (total_big_chances_scored + total_big_chances_missed),
      0
    ),
    # shot accuracy 
    shots_on_target_pct = ifelse(
      total_shots > 0,
      shots_on_target_inc_goals / total_shots,
      0
    ),
    
   
    # CREATION (per-90s)
    assists_per_90              = (goal_assists / minutes_played) * 90,
    key_passes_per_90           = (key_passes_attempt_assists / minutes_played) * 90,
    big_chances_created_per_90  = (total_big_chances_created / minutes_played) * 90,
    progressive_carries_per_90  = (progressive_carries / minutes_played) * 90,
    
    # percentage 
    dribble_success_rate        = ifelse(
      (successful_dribbles + unsuccessful_dribbles) > 0,
      successful_dribbles / (successful_dribbles + unsuccessful_dribbles),
      0
    ),
    
    
    # PHYSICAL
    recoveries_per_90           = (recoveries / minutes_played) * 90,
    tackles_won_per_90          = (tackles_won / minutes_played) * 90,
    fouls_won_per_90            = (total_fouls_won / minutes_played) * 90
    
    # aerial_duels_won_percentage and duels_won_percentage 
    # already rates from API — no calculation needed
    
  ) %>%
  
  # Keep only what we need going forward
  select(
    first_name, last_name, team, position,
    games_played, minutes_played,goals,nationality,
    
    # Attacking
    goals_per_90, shots_per_90,
    shots_on_target_per_90, box_touches_per_90, big_chance_conversion_pct,shots_on_target_pct,
    
    # Creation
    assists_per_90, key_passes_per_90, big_chances_created_per_90,
    progressive_carries_per_90, dribble_success_rate,
    
    # Physical
    aerial_duels_won_percentage, duels_won_percentage,
    recoveries_per_90, tackles_won_per_90, fouls_won_per_90
  )%>%
  
  
  mutate(across(where(is.numeric), ~ round(.x, 2)))



```


